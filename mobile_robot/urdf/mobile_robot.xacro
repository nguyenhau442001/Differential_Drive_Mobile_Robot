<?xml version="1.0"?>
<robot name="mobile_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- ================== Parameters ================== -->
  <!-- Chassis dimensions -->
  <xacro:property name="chassis_length" value="0.4"/>
  <xacro:property name="chassis_width"  value="0.2"/>
  <xacro:property name="chassis_height" value="0.1"/>
  <xacro:property name="chassis_mass"   value="15.0"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_thickness" value="0.05"/>
  <xacro:property name="wheel_mass" value="5.0"/>

  <!-- Wheel placement -->
  <xacro:property name="wheel_y_offset" value="${(chassis_width / 2) + (wheel_thickness / 2)}"/>
  <!-- Derived values -->
  <xacro:property name="wheel_separation" value="${2 * wheel_y_offset}"/>
  <xacro:property name="wheel_diameter" value="${2 * wheel_radius}"/>

  <!-- Caster dimensions -->
  <xacro:property name="caster_radius" value="0.05"/>
  <xacro:property name="caster_z_offset" value="-0.05"/>
  <xacro:property name="caster_front_x" value="0.15"/>
  <xacro:property name="caster_rear_x"  value="-0.15"/>

  <!-- Lidar dimensions -->
  <xacro:property name="lidar_size" value="0.1"/>
  <xacro:property name="lidar_x" value="0.15"/>
  <xacro:property name="lidar_z" value="0.1"/>
  <xacro:property name="lidar_mass" value="1e-5"/>

  <!-- ================== Includes ================== -->
  <xacro:include filename="$(find mobile_robot)/urdf/mobile_robot.gazebo" />
  <xacro:include filename="$(find mobile_robot)/urdf/materials.xacro" />

  <!-- 
    Robot Structure:
    - chassis (base)
    - caster (front & rear)
    - left_wheel_link
    - right_wheel_link
    - lidar_link
  -->

  <!-- ================== Base / Chassis ================== -->
  <link name="chassis">
    <pose>0 0 ${chassis_height/2} 0 0 0</pose>

    <!-- Inertia -->
    <inertial>
      <mass value="${chassis_mass}"/>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.1"/>
    </inertial>

    <!-- Collision (box) -->
    <collision name="chassis_collision">
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>

    <!-- Visual (box) -->
    <visual name="chassis_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </visual>

    <!-- Rear caster -->
    <collision name="caster_rear_collision">
      <origin xyz="${caster_rear_x} 0 ${caster_z_offset}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>0</mu>
            <mu2>0</mu2>
            <slip1>1.0</slip1>
            <slip2>1.0</slip2>
          </ode>
        </friction>
      </surface>
    </collision>

    <visual name="caster_rear_visual">
      <origin xyz="${caster_rear_x} 0 ${caster_z_offset}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </visual>

    <!-- Front caster -->
    <collision name="caster_front_collision">
      <origin xyz="${caster_front_x} 0 ${caster_z_offset}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>0</mu>
            <mu2>0</mu2>
            <slip1>1.0</slip1>
            <slip2>1.0</slip2>
          </ode>
        </friction>
      </surface>
    </collision>

    <visual name="caster_front_visual">
      <origin xyz="${caster_front_x} 0 ${caster_z_offset}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </visual>
  </link>
  <!-- ================== End Chassis ================== -->


  <!-- ================== Left Wheel ================== -->
  <link name="left_wheel_link">
    <collision name="left_wheel_collision">
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>

    <visual name="left_wheel_visual">
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.1"/>
    </inertial>
  </link>

  <joint type="continuous" name="left_wheel_joint">
    <origin xyz="0 ${wheel_y_offset} 0" rpy="0 0 0"/>
    <child link="left_wheel_link"/>
    <parent link="chassis"/>
    <axis xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
  </joint>
  <!-- ================== End Left Wheel ================== -->


  <!-- ================== Right Wheel ================== -->
  <link name="right_wheel_link">
    <collision name="right_wheel_collision">
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>

    <visual name="right_wheel_visual">
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5707 1.5707"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.1"/>
    </inertial>
  </link>

  <joint type="continuous" name="right_wheel_joint">
    <origin xyz="0 -${wheel_y_offset} 0" rpy="0 0 0"/>
    <child link="right_wheel_link"/>
    <parent link="chassis"/>
    <axis xyz="0 1 0"/>
    <limit effort="10000" velocity="1000"/>
  </joint>
  <!-- ================== End Right Wheel ================== -->


  <!-- ================== Lidar ================== -->
  <link name="lidar_link">
    <collision name="lidar_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${lidar_size} ${lidar_size} ${lidar_size}"/>
      </geometry>
    </collision>

    <visual name="lidar_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${lidar_size} ${lidar_size} ${lidar_size}"/>
      </geometry>
    </visual>

    <inertial>
      <mass value="${lidar_mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="${lidar_x} 0 ${lidar_z}" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="lidar_link"/>
  </joint>
  <!-- ================== End Lidar ================== -->

</robot>
