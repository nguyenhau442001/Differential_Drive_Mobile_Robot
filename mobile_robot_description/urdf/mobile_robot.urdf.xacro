<?xml version='1.0'?>
<robot name="mobile_robot_description" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================== Includes ================== -->
  <xacro:include filename="$(find mobile_robot_description)/urdf/mobile_robot.gazebo.xacro" />
  <xacro:include filename="$(find mobile_robot_description)/urdf/materials.xacro" />

  <!-- 
    Robot Structure Overview:
    - Chassis (base)
    - 4 Caster links (non-driven support wheels)
    - Left & Right drive wheels
    - Lidar sensor
  -->

  <!-- ========================================================= -->
  <!-- ================== Base / Chassis ======================= -->
  <!-- ========================================================= -->
  <link name="chassis">
    <inertial>
      <mass value="30"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="4.9887479320299" ixy="-0.000665021365264802" ixz="0.117153222467253"
        iyy="3.29577614857709" iyz="9.17818860502157E-07"
        izz="2.8376872224854"/>
    </inertial>

    <!-- Chassis Visual -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/chassis.STL"/></geometry>
      <material name=""><color rgba="0.647 0.620 0.588 1"/></material>
    </visual>

    <!-- Chassis Collision -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/chassis.STL"/></geometry>
    </collision>
  </link>

  <!-- ========================================================= -->
  <!-- =============== Casters (Support Spheres) =============== -->
  <!-- ========================================================= -->

  <!-- Caster Template -->
  <xacro:macro name="caster" params="name x y z">
    <link name="${name}_link">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.00018" ixy="0" ixz="0"
                 iyy="0.00018" iyz="0" 
                 izz="0.00018"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.03"/></geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.03"/></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu>
              <mu2>0.5</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="chassis"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- Instantiate 4 Casters -->
  <xacro:caster name="caster_front_left"  x="-0.165" y="0.09"  z="0.031"/>
  <xacro:caster name="caster_front_right" x="0.165"  y="0.09"  z="0.031"/>
  <xacro:caster name="caster_rear_left"   x="-0.165" y="-0.09" z="0.031"/>
  <xacro:caster name="caster_rear_right"  x="0.165"  y="-0.09" z="0.031"/>

  <!-- ========================================================= -->
  <!-- ======================== Wheels ========================= -->
  <!-- ========================================================= -->

  <!-- Left Wheel -->
  <link name="left_wheel_link">
    <inertial>
      <mass value="0.238"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00043" ixy="0" ixz="0"
               iyy="0.00081" iyz="0" izz="0.00043"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/left_wheel_link.STL"/></geometry>
      <material name=""><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/left_wheel_link.STL"/></geometry>
    </collision>
  </link>

  <!-- Left Wheel Joint -->
  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="0 0.241 0.074" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="left_wheel_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="20000" velocity="2.5"/>
    <dynamics damping="0.1" friction="1.0"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel_link">
    <inertial>
      <mass value="0.238"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00043" ixy="0" ixz="0"
               iyy="0.00081" iyz="0" izz="0.00043"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/right_wheel_link.STL"/></geometry>
      <material name=""><color rgba="0.79 0.82 0.93 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/right_wheel_link.STL"/></geometry>
    </collision>
  </link>

  <!-- Right Wheel Joint -->
  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="0 -0.241 0.074" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="right_wheel_link"/>
    <axis xyz="0 1 0"/>
    <limit effort="20000" velocity="2.5"/>
    <dynamics damping="0.1" friction="1.0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- =================== Lidar Sensor ======================== -->
  <!-- ========================================================= -->
  <link name="lidar_link">
    <inertial>
      <mass value="0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/lidar.STL"/></geometry>
      <material name=""><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><mesh filename="package://mobile_robot_description/meshes/lidar.STL"/></geometry>
    </collision>
  </link>

  <!-- Lidar Joint -->
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.265 0 0.089" rpy="0 0 0"/>
    <parent link="chassis"/>
    <child link="lidar_link"/>
    <axis xyz="0 0 0"/>
  </joint>
  <!-- ================== End Lidar ================== -->
</robot>
